# =============================================================================
# Nemesis Bot - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your Discord server.
#
#   cp .env.example .env
#
# NEVER commit the .env file - it contains secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Discord Bot Credentials
# -----------------------------------------------------------------------------
# Get these from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_bot_client_id
DISCORD_USER_ID=your_discord_user_id

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
DISCORD_SERVER_ID=your_discord_server_id

# Channel where match announcements are posted
ANNOUNCE_CHANNEL_ID=your_announcement_channel_id

# Voice channel used for watch parties (linked in Discord events)
WATCH_VC_ID=your_watch_party_voice_channel_id

# Direct link to the watch party channel (used as event location)
CHANNEL_LINK=https://discord.com/channels/SERVER_ID/WATCH_VC_ID

# Channel where bot commands and map veto reminders are sent
BOT_COMMANDS_CHANNEL_ID=your_bot_commands_channel_id

# Comma-separated user IDs to ping for map veto reminders
MAP_VETO_PING_USERS=210126672970776576,714702739908722742

# -----------------------------------------------------------------------------
# Permissions
# -----------------------------------------------------------------------------
# Comma-separated list of Discord role IDs that can use bot commands
ALLOWED_ROLES=role_id_1,role_id_2

# -----------------------------------------------------------------------------
# Game Role IDs (for @mentioning the correct role in announcements)
# -----------------------------------------------------------------------------
CS2_ROLE_ID=your_cs2_role_id
DOTA2_ROLE_ID=your_dota2_role_id
TRACKMANIA_ROLE_ID=your_trackmania_role_id
VALORANT_ROLE_ID=your_valorant_role_id
VALORANT_MOBILE_ROLE_ID=your_valorant_mobile_role_id
POKEMON_UNITE_ROLE_ID=your_pokemon_unite_role_id
HONOR_OF_KINGS_ROLE_ID=your_honor_of_kings_role_id
PUBG_ROLE_ID=your_pubg_role_id
PUBG_MOBILE_ROLE_ID=your_pubg_mobile_role_id
